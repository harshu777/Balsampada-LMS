# Database Configuration
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=tuition_lms
DB_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# Application Environment
NODE_ENV=production

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# Email Configuration (Required for email notifications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-specific-password
MAIL_FROM=noreply@tuitionlms.com

# Application URLs
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PgAdmin Configuration (Development)
PGADMIN_EMAIL=admin@tuitionlms.com
PGADMIN_PASSWORD=admin123

# Optional: Stripe Configuration (for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=

# Optional: Google OAuth (for social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Zoom Integration (for live classes)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=